{
  "name": "zcode-app-cli",
  "version": "3.3.5",
  "description": "Unofficial Bun and pi-tui terminal client for the ZCode agent runtime",
  "type": "module",
  "bin": {
    "zcode": "bin/zcode.ts"
  },
  "files": [
    "bin",
    "src",
    "vendor",
    "config.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:tui": "bun build packages/zcode-tui/src/index.ts --target=node --format=esm --outdir=packages/zcode-tui/dist --external=@earendil-works/pi-tui",
    "sync": "bun run build:tui && bun scripts/sync-runtime.ts",
    "sync:local": "bun run build:tui && bun scripts/sync-runtime.ts --app /Applications/ZCode.app",
    "check": "bun run build:tui && bun scripts/check-runtime.ts",
    "check:tui": "bun scripts/smoke-tui.ts && bun scripts/smoke-tui-features.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run check"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.19.0"
  },
  "packageManager": "bun@1.3.12",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.6",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "beautiful-mermaid": "^1.1.3",
    "typescript": "^7.0.2",
    "yaml": "^2.8.1"
  },
  "license": "MIT"
}
